# Database Configuration
DATABASE_URL="postgresql://<user>:<password>@<host>:<port>/<dbname>?pgbouncer=true"
DIRECT_URL="postgresql://<user>:<password>@<host>:<port>/<dbname>"

# Better Auth Configuration
# Generate a secret key (e.g. openssl rand -hex 32 or any strong random string)
BETTER_AUTH_SECRET="your_secret_key_here"
# Set to http://localhost:3000 for local development, or your production URL
BETTER_AUTH_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Google OAuth Credentials (optional, for production sign-in)
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""

# Redis Caching (optional, falls back to in-memory cache if not provided)
# REDIS_URL="redis://localhost:6379"

# Cloudflare R2 Storage (optional, falls back to local disk storage if not provided)
# R2_ACCOUNT_ID=""
# R2_ACCESS_KEY_ID=""
# R2_SECRET_ACCESS_KEY=""
# R2_BUCKET_NAME=""
# R2_PUBLIC_URL="https://<your-public-r2-domain>"
